{
  "packageManager": "pnpm@10.31.0",
  "name": "neuroinfoapi-client",
  "version": "1.5.0",
  "description": "A client for interacting with the NeuroInfoAPI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\"",
    "publishPackage": "powershell -ExecutionPolicy Bypass -File .\\publishAsk.ps1"
  },
  "keywords": [
    "neuroinfoapi",
    "nia",
    "vedal987",
    "neurosama",
    "neuro-sama"
  ],
  "author": "Appstun",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NeuroInfoAPI/NPM-Package/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuroInfoAPI/NPM-Package.git"
  },
  "homepage": "https://neuro.appstun.net/api/docs",
  "dependencies": {
    "ofetch": "^1.5.1"
  }
}
