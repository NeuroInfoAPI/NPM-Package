{
  "packageManager": "pnpm@10.30.2",
  "name": "neuroinfoapi-client",
  "version": "1.3.1",
  "description": "A client for interacting with the NeuroInfoAPI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\"",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "neuroinfoapi",
    "nia",
    "vedal987",
    "neurosama",
    "neuro-sama"
  ],
  "author": "Appstun",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6"
  }
}
